# Bússola Inteligente — Streamlit (Python)
language = "python3"
run = "pip install -q -r requirements.txt && streamlit run app.py --server.port=5000 --server.address=0.0.0.0 --server.headless=true"

entrypoint = "app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-23_11"

[[ports]]
localPort = 5000
externalPort = 80
