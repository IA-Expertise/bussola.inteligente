# Bússola Inteligente — Streamlit (Python)
language = "python3"
run = "pip install -q -r requirements.txt && streamlit run app.py --server.port=5000 --server.address=0.0.0.0 --server.headless=true"

entrypoint = "app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-23_11"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000 --server.address 0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port=5000", "--server.address=0.0.0.0", "--server.headless=true"]
build = ["pip", "install", "-r", "requirements.txt"]
